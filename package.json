    "@types/node": "^25.6.0",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.12"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "ink": "^7.0.0",
    "node-forge": "^1.4.0",
    "react": "^19.2.5"
  }
}
